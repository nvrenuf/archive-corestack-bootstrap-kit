{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corestack.local/packs/fear-signal-radar/schemas/topic_config.schema.json",
  "title": "FSRA TopicConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topic_id",
    "pillar",
    "description",
    "keywords_primary",
    "keywords_secondary",
    "platforms_enabled",
    "time_window_days",
    "language",
    "scoring_weights"
  ],
  "properties": {
    "topic_id": {
      "type": "string",
      "minLength": 1
    },
    "pillar": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "keywords_primary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "keywords_secondary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "platforms_enabled": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["reddit", "youtube", "news"]
      }
    },
    "subreddits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "youtube_queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "news_queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rss_feeds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "time_window_days": {
      "type": "integer",
      "minimum": 1,
      "default": 7
    },
    "language": {
      "type": "string",
      "minLength": 1,
      "default": "en"
    },
    "scoring_weights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "volume",
        "velocity",
        "cross_platform",
        "impact"
      ],
      "properties": {
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "velocity": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "cross_platform": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "impact": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        }
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "platforms_enabled": {
            "contains": {
              "const": "reddit"
            }
          }
        }
      },
      "then": {
        "required": ["subreddits"]
      }
    },
    {
      "if": {
        "properties": {
          "platforms_enabled": {
            "contains": {
              "const": "youtube"
            }
          }
        }
      },
      "then": {
        "required": ["youtube_queries"]
      }
    }
  ]
}
